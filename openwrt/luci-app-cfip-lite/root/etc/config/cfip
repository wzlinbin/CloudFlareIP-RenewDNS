config cfip 'main'
	option enabled '0'
	option run_mode 'dns_update'
	option source_mode 'official'
	option ip_api_url 'https://cloudflareip.ocisg.xyz/api/data'
	option custom_ip_api_url ''
	option auth_key ''
	option auth_client_id ''
	option auth_client_secret ''
	option auth_hwid ''
	option auto_register_once '1'
	option invite_code ''
	option auth_ephemeral_ttl_sec '180'
	option schedule_mode 'daily'
	option schedule_hour '3'
	option schedule_weekday '1'
	option schedule_monthday '1'
	option cf_api_token ''
	option cf_zone_id ''
	option cf_dns_name ''
	option tg_enabled '0'
	option tg_bot_token ''
	option tg_chat_id ''
	option tg_proxy_base_url 'https://cloudflareip.ocisg.xyz'
	option tg_auth_key ''
	option tg_disable_preview '1'
	option tg_timeout '10'
	option proxy_guard '1'
	option proxy_services 'passwall passwall2 shadowsocksr ssr-plus'
	option max_ips '200'
	option top_n '10'
	option timeout '15'
	option max_retries '3'
	option python_bin '/usr/bin/python3'
	option cfst_path '/usr/bin/CloudflareST'
	option script_path '/usr/libexec/cfip/cfip_lite.py'
	option work_dir '/tmp/cfip-lite'
