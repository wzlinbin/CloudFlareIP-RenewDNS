config cfip 'main'
	option enabled '0'
	option run_mode 'dns_update'
	option source_mode 'official'
	option ip_api_url 'https://cloudflareip.ocisg.xyz/api/data'
	option custom_ip_api_url ''
	option cf_api_token ''
	option cf_zone_id ''
	option cf_dns_name ''
	option max_ips '200'
	option top_n '10'
	option timeout '15'
	option max_retries '3'
	option python_bin '/usr/bin/python3'
	option cfst_path '/usr/bin/CloudflareST'
	option script_path '/usr/libexec/cfip/cfip_lite.py'
	option work_dir '/tmp/cfip-lite'
